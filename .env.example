# Continuum（原名 SuperHarness）API 配置
# 复制此文件为 .env 并填入真实值

# === 推荐配置（项目名称） ===
CONTINUUM_API_KEY=your-api-key-here
CONTINUUM_BASE_URL=https://api.anthropic.com
CONTINUUM_MODEL=claude-sonnet-4-6

# === 兼容配置（也支持） ===
# SUPERHARNESS_API_KEY=your-api-key-here
# SUPERHARNESS_BASE_URL=https://api.anthropic.com
# ANTHROPIC_API_KEY=your-api-key-here
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# === 多提供商支持（可选） ===
# OPENAI_API_KEY=your-openai-key
# GOOGLE_API_KEY=your-google-key
